# ── LLM ──────────────────────────────────────────────────────────────────
GROQ_TOKEN=gsk_...

# ── Travel APIs ───────────────────────────────────────────────────────────
# Single RapidAPI key covers Sky-Scrapper (flights) + Booking.com15 (hotels)
RAPIDAPI_KEY=...
# WeatherAPI.com — free tier is fine
WEATHERAPI_KEY=...

# ── Notifications ─────────────────────────────────────────────────────────
# Create a bot via @BotFather, get chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Image Generation ──────────────────────────────────────────────────────
# fal.ai key — https://fal.ai/dashboard/keys
FAL_API_KEY=...

# ── Persistence (optional) ────────────────────────────────────────────────
# Supabase postgres connection string — omit to use in-memory checkpointer
# SUPABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ── MCP Ports (optional — defaults shown) ────────────────────────────────
# MCP_TRAVEL_PORT=8001
# MCP_COMMS_PORT=8002
# MCP_MOODBOARD_PORT=8003
