# ── LLM ──────────────────────────────────────────────────────────────────
# Primary: Groq (https://console.groq.com/keys)
GROQ_TOKEN=gsk_...
# Fallback: OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# ── Web Search ────────────────────────────────────────────────────────────
# Tavily (https://tavily.com — 1000 req/month free)
TAVILY_API_KEY=tvly-dev-...

# ── Travel APIs ───────────────────────────────────────────────────────────
# RapidAPI (covers flights + hotels) — https://rapidapi.com
RAPIDAPI_KEY=...
# WeatherAPI.com — https://www.weatherapi.com/signup.aspx
WEATHERAPI_KEY=...

# ── Auth ──────────────────────────────────────────────────────────────────
# JWT secret — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=...

# ── Persistence ───────────────────────────────────────────────────────────
# Postgres connection string — omit for in-memory checkpointer
# SUPABASE_URL=postgresql://user:password@host:5432/dbname

# ── Docker ────────────────────────────────────────────────────────────────
# MCP_HOST=0.0.0.0
# MCP_TRAVEL_HOST=mcp-travel
# MCP_COMMS_HOST=mcp-comms
# MCP_SEARCH_HOST=mcp-search
